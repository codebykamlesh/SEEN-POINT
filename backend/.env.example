# =====================================================
# SEEN POINT — Backend Environment Configuration
# =====================================================
# Copy this file to .env and fill in your values

# ─── Server ───────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── Database (PostgreSQL) ────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=seenpoint_db
DB_USER=postgres
DB_PASSWORD=27032007
# Full connection string (Render.com provides this)
DATABASE_URL=postgresql://postgres:your_password_here@localhost:5432/seenpoint_db

# ─── JWT ──────────────────────────────────────────
JWT_SECRET=seenpoint_super_secret_jwt_key_change_in_production_min_32_chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=seenpoint_refresh_secret_key_change_in_production
JWT_REFRESH_EXPIRES_IN=30d

# ─── CORS Origins (comma-separated) ───────────────
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:5500,http://localhost:5500

# ─── Rate Limiting ────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200

# ─── Admin Credentials (for seeding) ─────────────
ADMIN_EMAIL=admin@seenpoint.com
ADMIN_PASSWORD=Admin@123

# ─── OneDrive / Microsoft Graph API ──────────────
# Register an app at https://portal.azure.com → Azure Active Directory → App registrations
ONEDRIVE_CLIENT_ID=your_azure_app_client_id_here
ONEDRIVE_CLIENT_SECRET=your_azure_app_client_secret_here
ONEDRIVE_TENANT_ID=common
ONEDRIVE_REDIRECT_URI=http://localhost:5000/api/onedrive/callback
# After OneDrive is connected, the folder ID where movies are stored
ONEDRIVE_MOVIES_FOLDER_ID=root

# ─── Frontend Serving (optional) ─────────────────
SERVE_FRONTEND=false

# ─── Optional: Redis (for caching) ───────────────
REDIS_URL=

# ─── SMTP (Gmail) for OTP Login ──────────────────
# 1. Enable 2FA on your Gmail: myaccount.google.com/security
# 2. Generate App Password: myaccount.google.com/apppasswords
# 3. Use the 16-character app password below (not your Gmail password)
SMTP_EMAIL=seenpointofficial@gmail.com
SMTP_PASSWORD=acye ebzv mwsh uqyg

